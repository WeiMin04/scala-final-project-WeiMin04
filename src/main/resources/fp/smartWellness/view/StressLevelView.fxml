<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800" prefWidth="1200" styleClass="background" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fp.smartWellness.view.StressLevelController">

    <children>
        <VBox spacing="25" AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50" AnchorPane.topAnchor="40">

            <!-- Title -->
            <Label styleClass="title" text="🧠 Stress Level Overview" />

            <!-- Card -->
            <VBox spacing="15" styleClass="card">

                <Label fx:id="stressLevelLabel" style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Stress Level: --" />

                <Label fx:id="reasonLabel" styleClass="subtext" wrapText="true" />

                <Label fx:id="suggestionLabel" style="-fx-font-size: 18px;" wrapText="true" />

            </VBox>

            <!-- Footer actions -->
            <HBox alignment="CENTER_LEFT" spacing="30">
                <Button onAction="#goDashboard" styleClass="default-button" text="Back to Dashboard" />

                <Label style="-fx-text-fill: #777;" text="This stress level is an estimate based on mood and sleep patterns." />
            </HBox>

        </VBox>
    </children>
</AnchorPane>
