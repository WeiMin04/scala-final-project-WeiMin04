<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="background" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fp.smartWellness.view.WelcomeController">
   <children>
      <VBox alignment="CENTER" layoutX="250.0" layoutY="91.0" prefHeight="200.0" prefWidth="100.0" spacing="20.0" stylesheets="@style.css" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="50.0">
         <children>
            <ImageView fitHeight="374.0" fitWidth="329.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../../images/welcome_illustration.png" />
               </image></ImageView>
            <Label alignment="CENTER" contentDisplay="CENTER" graphicTextGap="10.0" prefHeight="43.0" prefWidth="344.0" styleClass="title" text="Welcome to BloomWell" textAlignment="CENTER" wrapText="true" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="subtitle" text="Grow your habits. Thrive with better sleep, mood, and wellness.">
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin></Text>
            <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#handleGetStarted" styleClass="default-button" stylesheets="@style.css" text="Get Started" />
            <HBox alignment="CENTER" prefHeight="16.0" prefWidth="653.0" scaleShape="false">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="subtext" text="Already have account?" textAlignment="CENTER" />
                  <Hyperlink onAction="#handleLogin" styleClass="link" stylesheets="@style.css" text="Login" />
                  <Text layoutX="10.0" layoutY="25.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="subtext" text="now!" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
